# 환경설정 예시 — 복사해서 .env 로 사용 (모든 변수는 YGVCS_ 접두어)
# 운영 연결 시 실제 값으로 채우세요. 미설정 시 config.py 기본값 사용.

# --- 웹 서버 ---
YGVCS_APP_NAME=yg-vcs
YGVCS_HOST=0.0.0.0
YGVCS_PORT=8188
YGVCS_CONTEXT_PATH=/ygvcs

# --- MySQL (운영 DB) ---
YGVCS_DB_HOST=localhost
YGVCS_DB_PORT=3306
YGVCS_DB_NAME=yg_vcs_cloud
YGVCS_DB_USER=root
YGVCS_DB_PASSWORD=changeme
YGVCS_DB_POOL_SIZE=10
YGVCS_DB_POOL_MIN=5
# 개발 시 SQL 로그: true
YGVCS_DB_ECHO=false

# --- Redis ---
YGVCS_REDIS_HOST=localhost
YGVCS_REDIS_PORT=6379
YGVCS_REDIS_PASSWORD=
YGVCS_REDIS_DB=2
YGVCS_REDIS_TIMEOUT=5

# --- 차량 TCP 서버 ---
YGVCS_PRIMARY_SERVER_ENABLED=true
YGVCS_PRIMARY_SERVER_PORT=9112
YGVCS_COMMUNICATION_KEY=123456789
YGVCS_SERVER_VERSION=1.4.19

# --- 보조 서버(원본 기본 비활성) ---
YGVCS_CAM_SERVER_ENABLED=false
YGVCS_CAM_SERVER_PORT=9113
YGVCS_CALLBOX_SERVER_ENABLED=false
YGVCS_CALLBOX_SERVER_PORT=9114
YGVCS_WS_SERVER_ENABLED=false
YGVCS_WS_SERVER_PORT=9115

# --- 스케줄러 ---
YGVCS_SCHEDULER_ENABLED=true
